---
// Caixa de destaque (callout) pra dicas e truques dentro das receitas.
// Uso no markdown: {% note title="Dica" %} ...conteúdo... {% /note %}
// O conteúdo (children em bloco) é renderizado pelo renderer via slot.
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<aside class="note">
  {title && <p class="note__title">{title}</p>}
  <div class="note__body"><slot /></div>
</aside>
